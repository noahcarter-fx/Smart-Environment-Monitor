#include <Wire.h>
#include <LiquidCrystal_I2C.h>
#include <DHT.h>
#include <RTClib.h>

#define DHTPIN 2
#define DHTTYPE DHT11

#define MQ9_PIN A0
#define BUZZER_PIN 3

DHT dht(DHTPIN, DHTTYPE);
RTC_DS3231 rtc;

// LCD 1 = Temp / Humidity / Gas
LiquidCrystal_I2C lcd1(0x27, 16, 2);

// LCD 2 = Date / Time
LiquidCrystal_I2C lcd2(0x26, 16, 2);

int gasThreshold = 250;

unsigned long lastSwitchTime = 0;
bool showHumidity = false;

// 🔹 FLAG: Set to true ONLY ONCE to initialize RTC time, then set to false
#define SET_RTC_TIME false   // ⚠️ CHANGE TO true → Upload Once → Change back to false

void setup() {
  Serial.begin(9600);

  dht.begin();

  if (!rtc.begin()) {
    Serial.println("RTC not found");
    while (1);
  }

  // 🔹🔹🔹 RTC TIME INITIALIZATION 🔹🔹🔹
  if (SET_RTC_TIME) {
    // Option A: Set to compile/upload time (automatic)
    rtc.adjust(DateTime(F(__DATE__), F(__TIME__)));
    
    // Option B: Set manual time (uncomment below and comment Option A if preferred)
    // Format: DateTime(year, month, day, hour, minute, second)
    // rtc.adjust(DateTime(2025, 12, 25, 14, 30, 0));
    
    Serial.println("✅ RTC Time Updated!");
    delay(500);
  }

  lcd1.init();
  lcd1.backlight();

  lcd2.init();
  lcd2.backlight();

  pinMode(BUZZER_PIN, OUTPUT);
  digitalWrite(BUZZER_PIN, LOW);

  lcd1.setCursor(0, 0);
  lcd1.print("Air Monitor");
  lcd1.setCursor(0, 1);
  lcd1.print("Starting...");

  lcd2.setCursor(0, 0);
  lcd2.print("RTC: ");
  
  DateTime now = rtc.now();
  lcd2.setCursor(0, 1);
  if (now.day() < 10) lcd2.print("0");
  lcd2.print(now.day());
  lcd2.print("/");
  if (now.month() < 10) lcd2.print("0");
  lcd2.print(now.month());
  lcd2.print("/");
  lcd2.print(now.year());

  delay(2000);

  lcd1.clear();
  lcd2.clear();
}

// 🔹 Optional: Update time via Serial Monitor (send: YYYY,MM,DD,HH,MM,SS)
void handleSerialTimeUpdate() {
  if (Serial.available() >= 6) {
    int y = Serial.parseInt();
    int m = Serial.parseInt();
    int d = Serial.parseInt();
    int h = Serial.parseInt();
    int mn = Serial.parseInt();
    int s = Serial.parseInt();
    
    // Basic validation
    if (y >= 2020 && y <= 2100 && m >= 1 && m <= 12 && d >= 1 && d <= 31 &&
        h >= 0 && h <= 23 && mn >= 0 && mn <= 59 && s >= 0 && s <= 59) {
      rtc.adjust(DateTime(y, m, d, h, mn, s));
      Serial.println("✅ RTC Updated via Serial!");
      
      // Show confirmation on LCD2 briefly
      lcd2.clear();
      lcd2.print("Time Updated!");
      delay(1500);
    } else {
      Serial.println("❌ Invalid values! Use: YYYY,MM,DD,HH,MM,SS");
    }
    // Clear buffer
    while (Serial.available()) Serial.read();
  }
}

void loop() {
  // 🔹 Check for serial time update commands
  handleSerialTimeUpdate();

  float temperature = dht.readTemperature();
  float humidity = dht.readHumidity();
  int gasValue = analogRead(MQ9_PIN);

  DateTime now = rtc.now();

  // Buzzer logic
  if (gasValue > gasThreshold) {
    digitalWrite(BUZZER_PIN, HIGH);
  } else {
    digitalWrite(BUZZER_PIN, LOW);
  }

  // Change between humidity and gas every 30 seconds
  if (millis() - lastSwitchTime >= 30000) {
    showHumidity = !showHumidity;
    lastSwitchTime = millis();
  }

  // ---------------- LCD 1 ----------------
  lcd1.clear();
  lcd1.setCursor(0, 0);

  if (isnan(temperature)) {
    lcd1.print("Temp Error");
  } else {
    lcd1.print("Temp:");
    lcd1.print(temperature, 1);
    lcd1.print((char)223);  // Degree symbol
    lcd1.print("C");
  }

  lcd1.setCursor(0, 1);
  if (showHumidity) {
    if (isnan(humidity)) {
      lcd1.print("Humidity Err");
    } else {
      lcd1.print("Hum:");
      lcd1.print(humidity, 1);
      lcd1.print("%");
    }
  } else {
    lcd1.print("Gas:");
    lcd1.print(gasValue);
    if (gasValue <= 150) {
      lcd1.print(" Clean");
    } else if (gasValue <= 250) {
      lcd1.print(" Warn");
    } else {
      lcd1.print(" Alert");
    }
  }

  // ---------------- LCD 2 ----------------
  lcd2.clear();
  lcd2.setCursor(0, 0);

  // Date: DD/MM/YYYY
  if (now.day() < 10) lcd2.print("0");
  lcd2.print(now.day());
  lcd2.print("/");
  if (now.month() < 10) lcd2.print("0");
  lcd2.print(now.month());
  lcd2.print("/");
  lcd2.print(now.year());

  lcd2.setCursor(0, 1);
  // Time: HH:MM:SS
  if (now.hour() < 10) lcd2.print("0");
  lcd2.print(now.hour());
  lcd2.print(":");
  if (now.minute() < 10) lcd2.print("0");
  lcd2.print(now.minute());
  lcd2.print(":");
  if (now.second() < 10) lcd2.print("0");
  lcd2.print(now.second());

  // Serial Monitor Output
  Serial.print("Temperature: ");
  Serial.print(temperature);
  Serial.print(" C | Humidity: ");
  Serial.print(humidity);
  Serial.print(" % | Gas: ");
  Serial.print(gasValue);
  Serial.print(" | Date: ");
  Serial.print(now.day());
  Serial.print("/");
  Serial.print(now.month());
  Serial.print("/");
  Serial.print(now.year());
  Serial.print(" | Time: ");
  Serial.print(now.hour());
  Serial.print(":");
  Serial.print(now.minute());
  Serial.print(":");
  Serial.println(now.second());

  delay(1000);
}
